<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TripFactory × Cathay Pacific · Macau Campaign Summary 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold:#C9A84C;--gold-light:#E2C97E;--gold-dim:rgba(201,168,76,0.18);
  --dark:#0e0d0c;--dark-mid:#161513;--card:#1c1b19;
  --border:rgba(201,168,76,0.18);
  --cream:#F5F0E8;--orange:#C9682F;--teal:#1B5E52;--teal-dark:#0d3329;
  --white:#FFFFFF;--muted:rgba(245,240,232,0.52);--sub:rgba(245,240,232,0.78);
}
html{scroll-behavior:smooth}
body{background:var(--dark);color:var(--cream);font-family:'Montserrat',sans-serif;font-weight:300;overflow-x:hidden}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;justify-content:space-between;align-items:center;
  padding:14px 52px;
  background:rgba(14,13,12,0.95);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
}
.nav-brand{display:flex;align-items:center;gap:14px}
.nav-wordmark{font-family:'Playfair Display',serif;font-size:12px;letter-spacing:0.32em;text-transform:uppercase;color:var(--gold)}
.nav-sep{width:1px;height:18px;background:var(--border)}
.nav-sub{font-size:9px;letter-spacing:0.22em;text-transform:uppercase;color:var(--muted)}
.nav-links{display:flex;gap:28px}
.nav-links a{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s;cursor:pointer}
.nav-links a:hover{color:var(--gold)}

/* ── SECTION BASE ── */
section{width:100%;position:relative;overflow:hidden}
.pg-num{position:absolute;bottom:32px;right:52px;font-size:10px;letter-spacing:0.25em;color:var(--muted)}
.pg-num span{color:var(--gold)}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(24px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.in{opacity:1;transform:none}

/* ── SHARED TYPOGRAPHY ── */
.eyebrow{font-size:9.5px;letter-spacing:0.38em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.h1{font-family:'Playfair Display',serif;font-size:clamp(44px,6vw,80px);font-weight:400;line-height:1.06;color:var(--white);margin-bottom:14px}
.h1 em{font-style:italic;color:var(--gold)}
.h2{font-family:'Playfair Display',serif;font-size:clamp(28px,3.8vw,46px);font-weight:400;line-height:1.12;color:var(--white);margin-bottom:10px}
.h2 em{font-style:italic;color:var(--gold)}
.intro{font-size:13px;line-height:1.8;color:var(--muted);max-width:680px;margin-bottom:36px}
.gold-line{width:44px;height:2px;background:var(--gold);margin-bottom:28px;opacity:0.7}

/* ═══════════════════════════════
   PAGE 1 · COVER — full bleed hero
═══════════════════════════════ */
#p1{
  min-height:100vh;
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:0 64px 88px;
  background:
    linear-gradient(180deg,rgba(14,13,12,0.3) 0%,rgba(14,13,12,0.65) 42%,rgba(14,13,12,0.96) 100%),
    url('data:image/jpeg;base64,') center/cover no-repeat;
}
/* Thin gold + teal strip at top */
#p1::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--gold) 0%,var(--orange) 55%,var(--teal) 100%);
}
.cover-top{
  position:absolute;top:0;left:0;right:0;
  display:flex;justify-content:space-between;align-items:center;
  padding:22px 52px;
  background:rgba(14,13,12,0.0);
}
.cover-logo{font-family:'Playfair Display',serif;font-size:13px;letter-spacing:0.32em;text-transform:uppercase;color:var(--gold)}
.cover-conf{font-size:8.5px;letter-spacing:0.22em;text-transform:uppercase;color:rgba(245,240,232,0.45);border:1px solid rgba(201,168,76,0.22);padding:4px 12px}
.cover-body{position:relative;z-index:2}
.cover-flag{display:inline-flex;align-items:center;gap:9px;border:1px solid var(--border);padding:6px 16px 6px 10px;margin-bottom:32px}
.cf-dot{width:6px;height:6px;border-radius:50%;background:var(--gold)}
.cf-text{font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold)}
.cover-pills{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:40px}
.cpill{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;padding:7px 18px;border:1px solid var(--border);color:var(--gold-light);background:rgba(201,168,76,0.05)}
.cx{color:var(--muted);font-size:15px;font-weight:200}
.cover-date{margin-top:14px;font-size:11px;letter-spacing:0.18em;color:var(--muted)}

/* Right-side cover stats */
.cover-stats{
  position:absolute;right:64px;bottom:88px;
  display:flex;flex-direction:column;gap:0;
  z-index:2;
}
.cs-item{
  padding:18px 22px;border-left:2px solid var(--gold);
  margin-bottom:2px;background:rgba(14,13,12,0.55);
  backdrop-filter:blur(8px);
}
.cs-num{font-family:'Playfair Display',serif;font-size:30px;color:var(--gold);font-weight:400;line-height:1;margin-bottom:3px}
.cs-lbl{font-size:8.5px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(245,240,232,0.58);line-height:1.45}

/* ═══════════════════════════════
   PAGE 2 · BUSINESS OVERVIEW
═══════════════════════════════ */
#p2{background:var(--dark-mid);padding:120px 64px 80px}

.stats-bar{
  display:grid;grid-template-columns:repeat(5,1fr);
  gap:1px;background:var(--border);
  margin:0 0 2px;
}
.stat-cell{background:var(--card);padding:24px 18px;border-top:2px solid var(--gold)}
.stat-n{font-family:'Playfair Display',serif;font-size:34px;color:var(--gold);font-weight:400;line-height:1;margin-bottom:5px}
.stat-l{font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);line-height:1.5}

.brands-row{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);margin-bottom:2px}
.brand-card{background:var(--card);padding:26px 28px}
.bc-tag{display:inline-block;font-size:8.5px;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);border:1px solid var(--border);padding:3px 10px;margin-bottom:12px}
.bc-name{font-family:'Playfair Display',serif;font-size:22px;color:var(--white);margin-bottom:9px}
.bc-desc{font-size:12px;color:var(--muted);line-height:1.78}
.bc-metrics{display:flex;gap:18px;margin-top:14px;flex-wrap:wrap}
.bc-m{font-size:10.5px;color:var(--sub)}
.bc-m strong{display:block;font-family:'Playfair Display',serif;font-size:17px;color:var(--gold);font-weight:400;line-height:1.2}

.orn-strip{
  background:rgba(201,168,76,0.04);border:1px solid var(--border);
  padding:18px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;
}
.orn-label{font-size:9.5px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold)}
.orn-items{display:flex;gap:28px;flex-wrap:wrap}
.orn-item{font-size:12px;color:var(--sub);display:flex;align-items:center;gap:7px}
.orn-item::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--gold);flex-shrink:0}

/* ═══════════════════════════════
   PAGE 3 · MACAU OPPORTUNITY
   Full-bleed image panel on right
═══════════════════════════════ */
#p3{
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr 1fr;
  padding:0;
}
.p3-left{
  background:var(--dark);
  padding:120px 56px 80px;
  display:flex;flex-direction:column;justify-content:center;
  position:relative;
}
.p3-left::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--gold) 0%,var(--orange) 100%);
}
.p3-right{
  background:url('data:image/jpeg;base64,') center/cover no-repeat;
  position:relative;
  min-height:100vh;
}
.p3-right-overlay{
  position:absolute;inset:0;
  background:linear-gradient(90deg,rgba(14,13,12,0.65) 0%,rgba(14,13,12,0.15) 100%);
}
/* Route visual */
.route-box{background:var(--card);border:1px solid var(--border);padding:18px 20px;margin-bottom:16px}
.rb-label{font-size:8px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:12px}
.route-row{display:flex;align-items:center;gap:0;margin-bottom:8px}
.rn{background:var(--teal);padding:5px 12px;font-size:9.5px;font-weight:600;letter-spacing:0.07em;color:#c8e8e2}
.ra{flex:1;height:1px;background:rgba(201,168,76,0.22);position:relative}
.ra::after{content:'';position:absolute;right:-1px;top:-4px;border-top:4px solid transparent;border-bottom:4px solid transparent;border-left:6px solid rgba(201,168,76,0.5)}
.rd{background:rgba(201,168,76,0.1);border:1px solid var(--border);padding:5px 12px;font-size:9.5px;font-weight:600;color:var(--gold)}
.route-note{font-size:9px;color:var(--muted);margin-top:6px;line-height:1.55}
/* Detail list */
.detail-box{background:var(--card);border:1px solid var(--border);margin-bottom:16px}
.dl-row{display:flex;justify-content:space-between;padding:9px 16px;border-bottom:1px solid rgba(201,168,76,0.06);font-size:11px}
.dl-row:last-child{border-bottom:none}
.dk{color:var(--muted)}
.dv{color:var(--cream);text-align:right;max-width:55%;font-weight:400}
/* Targets */
.targets-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border)}
.tg-cell{background:var(--card);padding:16px 14px;text-align:center}
.tg-n{font-family:'Playfair Display',serif;font-size:24px;color:var(--gold);font-weight:400;line-height:1;margin-bottom:4px}
.tg-l{font-size:8.5px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);line-height:1.4}

/* Image mosaic on p3 right - layered captions */
.p3-img-caption{
  position:absolute;bottom:40px;left:32px;right:32px;
  background:rgba(14,13,12,0.7);backdrop-filter:blur(8px);
  padding:18px 22px;border-left:2px solid var(--gold);
}
.p3-caption-ey{font-size:8px;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin-bottom:4px}
.p3-caption-h{font-family:'Playfair Display',serif;font-size:20px;color:var(--white)}
.p3-caption-h em{font-style:italic;color:var(--gold)}

/* ═══════════════════════════════
   PAGE 4 · DELIVERABLES + BANNERS
═══════════════════════════════ */
#p4{background:var(--dark-mid);padding:120px 64px 100px}

.deliv-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:var(--border);
  margin:32px 0 48px;
}
.dg-cell{background:var(--card);padding:22px 20px}
.dg-letter{font-family:'Playfair Display',serif;font-size:30px;color:var(--gold);font-weight:400;line-height:1;margin-bottom:9px}
.dg-name{font-size:11px;font-weight:500;color:var(--white);margin-bottom:5px;letter-spacing:0.05em}
.dg-desc{font-size:10px;color:var(--muted);line-height:1.65}

/* ── BANNER SHOWCASE ── */
.banner-section-label{
  font-size:9.5px;letter-spacing:0.32em;text-transform:uppercase;color:var(--gold);
  margin-bottom:5px;
}
.banner-section-sub{font-size:11px;color:var(--muted);margin-bottom:22px}
.banners-wrap{display:flex;flex-direction:column;gap:24px}

/* Leaderboard */
.b-leader{
  width:100%;max-width:728px;height:88px;
  border:1px solid rgba(201,168,76,0.25);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 22px;overflow:hidden;position:relative;
  background:linear-gradient(135deg,rgba(13,51,41,0.95) 0%,rgba(17,16,16,0.98) 100%),
    url('data:image/jpeg;base64,') right/cover no-repeat;
  background-blend-mode:multiply,normal;
}
.b-leader::before{content:'WEB BANNER · 728×90';position:absolute;top:4px;left:8px;font-size:6.5px;letter-spacing:0.15em;color:rgba(255,255,255,0.18)}
.bl-left{}
.bl-ey{font-size:7px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(201,168,76,0.75);margin-bottom:4px}
.bl-head{font-family:'Playfair Display',serif;font-size:19px;color:var(--white);font-weight:400}
.bl-head em{color:var(--gold);font-style:italic}
.bl-logos{font-size:7px;letter-spacing:0.15em;color:rgba(255,255,255,0.35);margin-top:4px}
.bl-right{display:flex;align-items:center;gap:14px}
.bl-price{text-align:right}
.bl-from{font-size:7px;color:rgba(255,255,255,0.45);letter-spacing:0.1em;text-transform:uppercase}
.bl-amt{font-family:'Playfair Display',serif;font-size:18px;color:var(--gold)}
.bl-cta{background:var(--orange);padding:8px 16px;font-size:8px;letter-spacing:0.15em;text-transform:uppercase;color:#fff;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;font-weight:600;white-space:nowrap}

/* Pair row */
.b-pair{display:flex;gap:16px;align-items:flex-start}

/* Medium rect 300×250 */
.b-medium{
  width:300px;height:250px;flex-shrink:0;
  border:1px solid rgba(201,168,76,0.2);
  padding:20px;display:flex;flex-direction:column;justify-content:space-between;
  position:relative;overflow:hidden;
  background:linear-gradient(160deg,rgba(13,51,41,0.92) 0%,rgba(14,13,12,0.97) 80%),
    url('data:image/jpeg;base64,') center/cover no-repeat;
  background-blend-mode:multiply,normal;
}
.b-medium::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--orange))}
.bm-size{position:absolute;top:4px;right:6px;font-size:6.5px;letter-spacing:0.12em;color:rgba(255,255,255,0.2)}
.bm-ey{font-size:7px;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin-bottom:9px}
.bm-head{font-family:'Playfair Display',serif;font-size:20px;color:var(--white);line-height:1.2;margin-bottom:7px}
.bm-head em{color:var(--gold);font-style:italic}
.bm-body{font-size:9px;color:rgba(245,240,232,0.52);line-height:1.6;margin-bottom:8px}
.bm-bottom{display:flex;align-items:center;justify-content:space-between}
.bm-price{font-family:'Playfair Display',serif;font-size:14px;color:var(--gold)}
.bm-cta{background:var(--orange);padding:5px 11px;font-size:8px;letter-spacing:0.12em;text-transform:uppercase;color:#fff;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;font-weight:600}

/* Half page 300×600 */
.b-half{
  width:300px;height:408px;flex-shrink:0;
  border:1px solid rgba(201,168,76,0.2);
  overflow:hidden;display:flex;flex-direction:column;
  position:relative;
  background:url('data:image/jpeg;base64,') center/cover no-repeat;
}
.bh-overlay{
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(14,13,12,0.2) 0%,rgba(14,13,12,0.78) 55%,rgba(14,13,12,0.97) 100%);
}
.bh-size{position:absolute;top:6px;right:8px;font-size:6.5px;letter-spacing:0.12em;color:rgba(255,255,255,0.25);z-index:2}
.bh-content{position:absolute;bottom:0;left:0;right:0;padding:22px;z-index:2}
.bh-ey{font-size:7px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.bh-head{font-family:'Playfair Display',serif;font-size:22px;color:var(--white);line-height:1.18;margin-bottom:10px}
.bh-head em{color:var(--gold);font-style:italic}
.bh-itins{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.bh-itin{display:flex;justify-content:space-between;font-size:10px;padding:6px 10px;background:rgba(201,168,76,0.08);border-left:2px solid var(--gold)}
.bh-itin-name{color:var(--sub)}
.bh-itin-price{color:var(--gold);font-family:'Playfair Display',serif;font-size:12px}
.bh-cta{display:block;background:var(--orange);padding:9px;text-align:center;font-size:8.5px;letter-spacing:0.18em;text-transform:uppercase;color:#fff;font-weight:600;font-family:'Montserrat',sans-serif;cursor:pointer;border:none;width:100%}

/* Social square + push stack */
.b-socials-col{flex:1;display:flex;flex-direction:column;gap:12px}

/* Social tile */
.b-social{
  border:1px solid rgba(201,168,76,0.2);
  overflow:hidden;height:192px;
  display:flex;flex-direction:column;
  background:url('data:image/webp;base64,') center/cover no-repeat;
  position:relative;
}
.bso-overlay{
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(14,13,12,0.18) 0%,rgba(14,13,12,0.88) 100%);
}
.bso-size{position:absolute;top:6px;right:8px;font-size:6.5px;letter-spacing:0.12em;color:rgba(255,255,255,0.3);z-index:2}
.bso-content{position:absolute;bottom:0;left:0;right:0;padding:14px 16px;z-index:2}
.bso-ey{font-size:7px;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin-bottom:5px}
.bso-head{font-family:'Playfair Display',serif;font-size:15px;color:var(--white);line-height:1.25;margin-bottom:6px}
.bso-head em{font-style:italic;color:var(--gold)}
.bso-row{display:flex;justify-content:space-between;align-items:center}
.bso-tag{font-size:8px;color:rgba(245,240,232,0.5);letter-spacing:0.08em}
.bso-cta{font-size:8px;color:var(--orange);font-weight:600;letter-spacing:0.1em;text-transform:uppercase}

/* Push notifications */
.b-push{background:var(--card);border:1px solid var(--border);padding:14px 16px;border-radius:12px;display:flex;align-items:flex-start;gap:12px}
.bp-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.bp-app{font-size:8.5px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:3px}
.bp-title{font-size:12.5px;font-weight:500;color:var(--white);margin-bottom:3px}
.bp-body{font-size:10.5px;color:var(--muted);line-height:1.5}
.bp-time{font-size:9px;color:var(--muted);margin-top:5px}

/* Email */
.b-email{width:100%;max-width:560px;background:var(--card);border:1px solid rgba(201,168,76,0.15);overflow:hidden;margin-top:24px}
.be-header{
  padding:20px 26px;
  background:linear-gradient(160deg,rgba(13,51,41,0.95) 0%,rgba(17,16,16,0.98) 100%),
    url('data:image/webp;base64,') center/cover no-repeat;
  background-blend-mode:multiply,normal;
  display:flex;justify-content:space-between;align-items:center;
}
.be-brand{font-family:'Playfair Display',serif;font-size:18px;color:var(--cream);letter-spacing:0.08em}
.be-sub{font-size:8px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(212,237,232,0.55)}
.be-body{padding:28px 26px;text-align:center}
.be-ey{font-size:8.5px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:9px}
.be-head{font-family:'Playfair Display',serif;font-size:26px;color:var(--white);line-height:1.2;margin-bottom:7px}
.be-head em{color:var(--gold);font-style:italic}
.be-copy{font-size:11px;color:var(--muted);margin-bottom:16px;line-height:1.6}
.be-cta{display:inline-block;background:var(--orange);padding:10px 26px;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#fff;font-weight:600;font-family:'Montserrat',sans-serif;cursor:pointer}
.be-pkgs{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:rgba(201,168,76,0.1)}
.be-pkg{background:var(--card);padding:14px;text-align:center}
.be-pkg-l{font-size:8px;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
.be-pkg-n{font-family:'Playfair Display',serif;font-size:12.5px;color:var(--white);margin-bottom:3px}
.be-pkg-p{font-size:11px;color:var(--gold)}
.be-footer{padding:12px 26px;text-align:center;border-top:1px solid rgba(201,168,76,0.08)}
.be-footer-t{font-size:8px;letter-spacing:0.1em;color:rgba(255,255,255,0.2)}

/* Commit bar */
.commit-bar{
  background:rgba(201,168,76,0.04);border:1px solid var(--border);
  padding:20px 28px;margin-top:40px;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;
}
.commit-text{font-size:13px;color:var(--sub)}
.commit-text strong{color:var(--gold);font-weight:500}
.commit-stats{display:flex;gap:26px;flex-wrap:wrap}
.cs-stat{text-align:right}
